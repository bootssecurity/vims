{
  "name": "@vims/framework",
  "version": "0.1.0",
  "description": "Core runtime framework for the VIMS platform.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vims-dev/vims.git",
    "directory": "packages/core/framework"
  },
  "homepage": "https://github.com/vims-dev/vims/tree/main/packages/core/framework",
  "bugs": {
    "url": "https://github.com/vims-dev/vims/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "default": "./dist/container.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "default": "./dist/modules.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration.d.ts",
      "default": "./dist/orchestration.js"
    },
    "./policies": {
      "types": "./dist/policies.d.ts",
      "default": "./dist/policies.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./workflows": {
      "types": "./dist/workflows.d.ts",
      "default": "./dist/workflows.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vims/config": "0.1.0",
    "@vims/container": "0.1.0",
    "@vims/events": "0.1.0",
    "@vims/logger": "0.1.0",
    "@vims/orchestration": "0.1.0",
    "@vims/policies": "0.1.0",
    "@vims/workflows": "0.1.0"
  }
}
