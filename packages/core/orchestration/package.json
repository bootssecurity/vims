{
  "name": "@vims/orchestration",
  "version": "0.1.0",
  "description": "VIMS utilities to orchestrate modules and workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vims-dev/vims.git",
    "directory": "packages/core/orchestration"
  },
  "homepage": "https://github.com/vims-dev/vims/tree/main/packages/core/orchestration",
  "bugs": {
    "url": "https://github.com/vims-dev/vims/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vims/utils": "0.1.0"
  }
}
